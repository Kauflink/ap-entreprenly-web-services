{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=<DATABASE_HOST>;port=3306;database=<DATABASE_NAME>;User Id=<DATABASE_USER>;password=<DATABASE_PASSWORD>"
  },
  "TokenSettings": {
    "Secret": "<LOCAL_DEV_JWT_SECRET>"
  },
  "WhatsAppBridge": {
    "BridgeUrl": "http://localhost:3001",
    "BridgeToken": "<WHATSAPP_BRIDGE_TOKEN>"
  }
}

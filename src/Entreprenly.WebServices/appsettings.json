{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "server=/cloudsql/%DATABASE_PROJECT%:%DATABASE_REGION%:%DATABASE_INSTANCE%;database=%DATABASE_NAME%;User Id=%DATABASE_USER%;AllowPublicKeyRetrieval=True"
  },
  "TokenSettings": {
    "Secret": "%TOKEN_SECRET%"
  },
  "WhatsAppBridge": {
    "BridgeUrl": "%WHATSAPP_BRIDGE_URL%",
    "BridgeToken": "%BRIDGE_TOKEN%"
  }
}

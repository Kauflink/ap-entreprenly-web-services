# Copy to app.env on the VM as /opt/app/app.env (never commit the real file).
# Database connection (MySQL on vm-database, reached via the private VPC IP).
#
# IMPORTANT: docker compose interpolates env_file values, so any literal '$' in a
# value must be doubled to '$$'. Example: a password "$secret" is written "$$secret".
ConnectionStrings__DefaultConnection=server=10.0.0.5;port=3306;database=ap-entreprenly;user=admin;password=CHANGE_ME

# JWT signing secret (use a long random value, e.g. `openssl rand -base64 48`).
TokenSettings__Secret=CHANGE_ME
